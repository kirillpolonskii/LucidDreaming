<?xml version="1.0" encoding="utf-8"?>
<MotionScene
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto"
    >
    <Transition
        motion:constraintSetStart="@id/toppanel_hidden"
        motion:constraintSetEnd="@id/toppanel_expanded"
        motion:duration="1000"

        >
        <OnSwipe
            motion:touchAnchorId="@id/tpDreamDetailsMeta"
            motion:touchAnchorSide="bottom"
            motion:dragDirection="dragDown" />
    </Transition>
    <Transition
        motion:constraintSetStart="@id/toppanel_hidden"
        motion:constraintSetEnd="@id/toppanel_expanded"
        motion:duration="100"
        >
        <OnClick
            motion:clickAction="transitionToEnd"
            motion:targetId="@id/ibtnDreamDetailsShowMeta"
            />
    </Transition>
    <!--motion:touchRegionId="@id/ibtnDreamDetailsShowMeta"-->

    <ConstraintSet android:id="@+id/toppanel_hidden">
        <Constraint
            android:id="@+id/ibtnDreamDetailBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toStartOf="@id/tvDreamDetailsTitle"
            motion:layout_constraintTop_toTopOf="@id/tvDreamDetailsTitle"
            motion:layout_constraintBottom_toBottomOf="@id/tvDreamDetailsTitle"
            motion:layout_constraintHorizontal_bias="0"
            motion:layout_constraintHorizontal_chainStyle="packed"

            />
        <Constraint
            android:id="@+id/tvDreamDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toEndOf="@id/ibtnDreamDetailBack"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toTopOf="@id/ibtnDreamDetailsShowMeta"
            motion:layout_constraintHorizontal_bias="0"
            />
        <Constraint
            android:id="@id/etDreamDetailsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintTop_toBottomOf="@id/vwDreamDetailsButtonStripeLeft"
            />
        <Constraint
            android:id="@+id/tpDreamDetailsMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintBottom_toTopOf="@id/tvDreamDetailsTitle"
            />

    </ConstraintSet>

    <ConstraintSet android:id="@+id/toppanel_expanded">
        <Constraint
            android:id="@+id/ibtnDreamDetailBack"
            android:visibility="gone"
            />
        <Constraint
            android:id="@+id/tvDreamDetailsTitle"
            android:visibility="gone"
            />
        <Constraint
            android:id="@+id/ibtnDreamDetailsShowMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toEndOf="@id/vwDreamDetailsButtonStripeLeft"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintTop_toBottomOf="@id/tpDreamDetailsMeta"
            />
        <Constraint
            android:id="@id/etDreamDetailsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintTop_toTopOf="parent"
            />
        <Constraint
            android:id="@+id/tpDreamDetailsMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            motion:layout_constraintTop_toTopOf="parent"
            />

    </ConstraintSet>
</MotionScene>