<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LDButton">
        <item name="backgroundTint">@null</item>
    </style>

    <style name="LDButton.Round" parent="LDButton">
        <item name="android:background">@drawable/selector_all_roundbtn</item>
    </style>

    <style name="LDButton.BottomRound" parent="LDButton">
        <item name="android:background">@drawable/selector_all_bottomroundbtn</item>
        <item name="android:padding">@dimen/padding_all_bottomroundbtn</item>
    </style>

    <style name="LDTextView">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="LDImageView">
        <item name="android:background">@drawable/selector_settings_themebtn</item>
        <item name="android:scaleType">fitXY</item>
        <item name="android:padding">10dp</item>
        <!--<item name="android:clickable">true</item>-->
    </style>
    
</resources>