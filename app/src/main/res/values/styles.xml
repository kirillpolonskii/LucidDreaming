<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LDButton">
        <item name="backgroundTint">@null</item>
    </style>

    <style name="LDButton.Round" parent="LDButton">
        <item name="android:background">@drawable/selector_all_roundbtn</item>
    </style>

    <style name="LDButton.BottomRound" parent="LDButton">
        <item name="android:background">@drawable/selector_all_bottomroundbtn</item>
