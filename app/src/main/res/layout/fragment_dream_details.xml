<?xml version="1.0" encoding="utf-8"?>
<com.youngsophomore.luciddreaming.ui.custom.DreamDetailsMotionLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layoutDescription="@xml/scene_dreamdetails_toppanel"

    >

    <ImageButton
        android:id="@+id/ibtnDreamDetailBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:src="@drawable/all_arrowback_24"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etDreamDetailsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintHorizontal_chainStyle="packed"

        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        />

    <View
        android:id="@+id/vwDreamDetailsButtonStripe"
        android:layout_width="0dp"
        android:layout_height="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tpDreamDetailsMeta"
    
        android:background="@drawable/selector_all_bottomroundbtn"
        />

    <ImageButton
        android:id="@+id/ibtnDreamDetailsShowMeta"
        style="@style/LDButton.BottomRound"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/ibtnDreamDetailBack"
        app:layout_constraintEnd_toStartOf="@id/ibtnDreamDetailSaveEdit"
        app:layout_constraintTop_toBottomOf="@id/vwDreamDetailsButtonStripe"

        android:contentDescription="TODO"
        android:src="@drawable/dreamdetails_showmeta_24"
        android:layout_marginHorizontal="60dp"


        />

    <ImageButton
        android:id="@+id/ibtnDreamDetailSaveEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etDreamDetailsTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintHorizontal_chainStyle="packed"

        android:background="@android:color/transparent"
        android:src="@drawable/all_save_24"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        />


    <EditText
        android:id="@+id/etDreamDetailsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ibtnDreamDetailBack"

        android:hint="@string/dreamdetails_titlehint"

        android:autofillHints="name"
        />
    <EditText
        android:id="@+id/etDreamDetailsContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etDreamDetailsTitle"
        app:layout_constraintBottom_toBottomOf="parent"

        android:backgroundTint="@color/md_theme_onPrimaryContainer"
        android:autofillHints="@null"
        android:gravity="top"
        />

    <com.youngsophomore.luciddreaming.ui.custom.MetaTopPanelPortrait
        android:id="@+id/tpDreamDetailsMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="parent"

        android:clickable="false"
        />

</com.youngsophomore.luciddreaming.ui.custom.DreamDetailsMotionLayout>