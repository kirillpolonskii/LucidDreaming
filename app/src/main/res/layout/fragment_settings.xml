<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.fragments.SettingsFragment">

    <ImageButton
        android:id="@+id/ibtnSettingsBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toTopOf="parent"

        android:background="@android:color/transparent"
        android:src="@drawable/all_arrowback_24"
        android:layout_margin="10dp"
        />
    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/ibtnSettingsBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        android:text="Settings"

        />


    <TextView
        android:id="@+id/tvSettingsNotifsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle"
        app:layout_constraintBottom_toTopOf="@id/tvSettingsNotifsActiveHoursSubtitle"
        app:layout_constraintHorizontal_bias="0"

        android:text="Включить слабые уведомления"

        />
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/swchSettingsNotifs"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        app:layout_constraintStart_toEndOf="@id/tvSettingsNotifsTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvSettingsNotifsTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvSettingsNotifsTitle"

        />
    <TextView
        android:id="@+id/tvSettingsNotifsActiveHoursSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvSettingsNotifsActiveHoursStart"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsNotifsTitle"
        app:layout_constraintBottom_toTopOf="@id/tvSettingsNotifsFrequencySubtitle"

        android:text="Период активности"

        />
    <TextView
        android:id="@+id/tvSettingsNotifsActiveHoursStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/tvSettingsNotifsActiveHoursSubtitle"
        app:layout_constraintEnd_toStartOf="@id/tvSettingsNotifsActiveHoursDash"
        app:layout_constraintTop_toTopOf="@id/tvSettingsNotifsActiveHoursSubtitle"
        app:layout_constraintBottom_toBottomOf="@id/tvSettingsNotifsActiveHoursSubtitle"


        android:text="08:00"
        />
    <TextView
        android:id="@+id/tvSettingsNotifsActiveHoursDash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/tvSettingsNotifsActiveHoursStart"
        app:layout_constraintEnd_toStartOf="@id/tvSettingsNotifsActiveHoursEnd"
        app:layout_constraintTop_toTopOf="@id/tvSettingsNotifsActiveHoursSubtitle"
        app:layout_constraintBottom_toBottomOf="@id/tvSettingsNotifsActiveHoursSubtitle"

        android:text=" - "

        />
    <TextView
        android:id="@+id/tvSettingsNotifsActiveHoursEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/tvSettingsNotifsActiveHoursDash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvSettingsNotifsActiveHoursSubtitle"
        app:layout_constraintBottom_toBottomOf="@id/tvSettingsNotifsActiveHoursSubtitle"

        android:text="23:00"
        />

    <TextView
        android:id="@+id/tvSettingsNotifsFrequencySubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/sprSettingsNotifsFrequency"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsNotifsActiveHoursSubtitle"
        app:layout_constraintBottom_toTopOf="@id/tvSettingsThemesTitle"

        android:text="Интервал между уведомлениями"
        />
    <Spinner
        android:id="@+id/sprSettingsNotifsFrequency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/tvSettingsNotifsFrequencySubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvSettingsNotifsFrequencySubtitle"
        app:layout_constraintBottom_toBottomOf="@id/tvSettingsNotifsFrequencySubtitle"

        android:entries="@array/frequencies"

        />

    <TextView
        android:id="@+id/tvSettingsThemesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sprSettingsNotifsFrequency"
        app:layout_constraintBottom_toTopOf="@id/hscrvwSettingsThemes"

        android:text="Выбор темы"

        />
    <HorizontalScrollView
        android:id="@+id/hscrvwSettingsThemes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsThemesTitle"
        app:layout_constraintBottom_toTopOf="@id/tvSettingsPasswordTitle">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"

            >
            <ImageView
                android:id="@+id/ivSettingsThemeBlue"
                android:layout_width="210dp"
                android:layout_height="400dp"

                android:src="@drawable/settings_blue_theme_raw"
                android:scaleType="fitXY"
                android:layout_marginHorizontal="15dp"

                />
            <ImageView
                android:id="@+id/ivSettingsThemePurple"
                android:layout_width="210dp"
                android:layout_height="400dp"

                android:src="@drawable/settings_blue_theme_raw"
                android:scaleType="fitXY"
                android:layout_marginHorizontal="15dp"
                />
            <ImageView
                android:id="@+id/ivSettingsThemeGreen"
                android:layout_width="210dp"
                android:layout_height="400dp"

                android:src="@drawable/settings_blue_theme_raw"
                android:scaleType="fitXY"
                android:layout_marginHorizontal="15dp"
                />
            <ImageView
                android:id="@+id/ivSettingsThemePink"
                android:layout_width="210dp"
                android:layout_height="400dp"

                android:src="@drawable/settings_blue_theme_raw"
                android:scaleType="fitXY"
                android:layout_marginHorizontal="15dp"
                />
        </LinearLayout>

    </HorizontalScrollView>
    <TextView
        android:id="@+id/tvSettingsPasswordTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hscrvwSettingsThemes"
        app:layout_constraintBottom_toTopOf="@id/swchSettingsPassword"

        android:text="Вход в список снов по паролю"

        />
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/swchSettingsPassword"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsPasswordTitle"
        app:layout_constraintBottom_toTopOf="@id/tvSettingsLanguageTitle"

        />
    <TextView
        android:id="@+id/tvSettingsLanguageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/swchSettingsPassword"
        app:layout_constraintBottom_toTopOf="@id/sprSettingsLanguage"

        android:text="Язык приложения"

        />
    <Spinner
        android:id="@+id/sprSettingsLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsLanguageTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        />


</androidx.constraintlayout.widget.ConstraintLayout>